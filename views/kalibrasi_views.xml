<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- 1. LIST VIEW -->
    <record id="view_kalibrasi_alat_kesehatan_list" model="ir.ui.view">
        <field name="name">kalibrasi.alat.kesehatan.list</field>
        <field name="model">kalibrasi.alat.kesehatan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="product_id"/>
                <field name="tanggal_kalibrasi"/>
                <field name="hasil"/>
                <field name="tanggal_berikutnya"/>
                <field name="status"/>
            </list>
        </field>
    </record>
    
    <!-- 2. FORM VIEW -->
    <record id="view_kalibrasi_alat_kesehatan_form" model="ir.ui.view">
        <field name="name">kalibrasi.alat.kesehatan.form</field>
        <field name="model">kalibrasi.alat.kesehatan</field>
        <field name="arch" type="xml">
            <form>

            </form>
        </field>
    </record>
    
    <!-- 3. SEARCH VIEW -->
    <record id="view_kalibrasi_alat_kesehatan_search" model="ir.ui.view">
        <field name="name">kalibrasi.alat.kesehatan.search</field>
        <field name="model">kalibrasi.alat.kesehatan</field>
        <field name="arch" type="xml">
            <search>

            </search>
        </field>
    </record>
    
    <!-- 4. ACTION + MODEL -->
    <record id="action_kalibrasi_alat_kesehatan" model="ir.actions.act_window">
        <field name="name">Kalibrasi Alat Kesehatan</field>
        <field name="res_model">kalibrasi.alat.kesehatan</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem />

</odoo>